# CryptoPilot local development environment

DATABASE_URL="postgresql://cryptopilot:cryptopilot_dev_password@localhost:5432/cryptopilot?schema=public"
REDIS_URL="redis://localhost:6379"

APP_URL="http://localhost:3000"
ADMIN_APP_URL="http://localhost:3001"
ADMIN_URL="http://localhost:3001"
API_URL="http://localhost:3002"
NEXT_PUBLIC_API_URL="http://localhost:3002"
NEXT_PUBLIC_DEMO_USER_ID="00000000-0000-0000-0000-000000000002"
NEXT_PUBLIC_ADMIN_USER_ID="00000000-0000-0000-0000-000000000001"

AUTH_SECRET="change-me-for-local-development"
# 后台自动任务开关：本地默认关闭；线上 API 需要显式设为 true 才会自动采集、生成 AI、聚类和同步价格
ENABLE_BACKGROUND_JOBS="false"
# Magic Link：非 production 默认在 API 响应中返回链接；生产请设 MAGIC_LINK_EXPOSE=false 并接邮件服务
MAGIC_LINK_EXPOSE="true"
# Resend 邮件发送：生产环境用于发送 Magic Link 登录邮件
RESEND_API_KEY=""
MAIL_FROM="CryptoPilot <noreply@cryptopilot.chat>"
# Telegram Push：V0.5 绑定和推送功能需要配置真实 Bot Token；Webhook Secret 用于校验 Telegram 回调
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""
# Demo 快捷登录：非 production 默认允许；生产如需临时保留才设 true
BETA_DEV_LOGIN="false"
# Beta 允许任意邮箱注册（生产务必 false）
BETA_ALLOW_SIGNUP="false"
NEXT_PUBLIC_BETA_DEV_LOGIN="true"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- LLM 路由（见 docs/modules/LLM_Providers.md）---
# 默认 chat；未单独配置的功能会回退到此
LLM_DEFAULT="moonshot"
# 兼容旧变量名（与 LLM_DEFAULT 等价）
LLM_PROVIDER="moonshot"
# 按功能指定 registry 中的 id（openai | deepseek | moonshot | kimi）
LLM_ROUTE_AI_SEARCH="moonshot"
# 可选：Feed 摘要改用 DeepSeek 时取消注释
# LLM_ROUTE_FEED_SUMMARY="deepseek"
LLM_ROUTE_EMBEDDING="openai"

LLM_TEMPERATURE="0.6"
LLM_MAX_OUTPUT_TOKENS="1200"

# moonshot / kimi
MOONSHOT_API_KEY=""
MOONSHOT_BASE_URL="https://api.moonshot.cn/v1"
MOONSHOT_CHAT_MODEL="kimi-k2.5"

# deepseek
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_CHAT_MODEL="deepseek-v4-pro"

# openai（Embedding 仅 openai 走真实 API，其它提供商用 mock 向量）
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
