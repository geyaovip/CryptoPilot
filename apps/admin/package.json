{
  "name": "@cryptopilot/admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "build:cloudflare": "NEXT_PUBLIC_API_URL=https://api.cryptopilot.chat API_URL=https://api.cryptopilot.chat NEXT_PUBLIC_BETA_DEV_LOGIN=false opennextjs-cloudflare build",
    "deploy:cloudflare": "node ../../scripts/assert-cloudflare-build-env.mjs admin && opennextjs-cloudflare deploy",
    "preview:cloudflare": "opennextjs-cloudflare preview",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cryptopilot/config": "workspace:*",
    "@cryptopilot/types": "workspace:*",
    "@cryptopilot/ui": "workspace:*",
    "@tanstack/react-query": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "jsdom": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "^4.93.1"
  }
}
